<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.VideoConverterTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Video Conversion"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Convert SFD, PSS, BIK, VID1 (.vid), and STR (PS1 MDEC) video files to MP4"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: file list + preview -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition x:Name="SplitterColumn" Width="0" />
        <ColumnDefinition x:Name="PreviewColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <controls:GridSplitter
        x:Name="PreviewSplitter"
        Grid.Column="1"
        Width="8"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Columns"
        Visibility="Collapsed" />

      <!-- File list card -->
      <Border
        x:Name="FileListCard"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <Grid VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Column headers -->
          <Grid Grid.Row="0"
                Style="{StaticResource ColumnHeaderGridStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="100" />
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" Margin="8,0,0,0" />
            <TextBlock Grid.Column="1" Text="Duration" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="Resolution" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="Size" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" />
          </Grid>

          <!-- Files ListView -->
          <ListView
            x:Name="FilesListView"
            Grid.Row="1"
            SelectionMode="Single"
            Style="{StaticResource FileListViewStyle}"
            SelectionChanged="FilesListView_SelectionChanged">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="local:SfdFileEntry">
                <Grid Style="{StaticResource ListItemRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="100" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Text="{x:Bind FileName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTipService.ToolTip="{x:Bind FileName}" />
                  <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind DurationDisplay}" />
                  <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind ResolutionDisplay}" />
                  <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind SizeDisplay}" />
                  <TextBlock
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Foreground="{x:Bind StatusColor, Mode=OneWay}"
                    Text="{x:Bind StatusDisplay, Mode=OneWay}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Empty state -->
      <Border
        x:Name="EmptyStatePanel"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <FontIcon FontSize="64"
                    Glyph="&#xE714;"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock
            Text="No directory selected"
            FontSize="18"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextAlignment="Center" />
          <TextBlock
            Text="Select a folder of video files or a game archive (WAD/PRE/PKR/PAK/...)"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            TextAlignment="Center"
            TextWrapping="Wrap"
            MaxWidth="440" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <Button
              Content="Browse folder..."
              Click="InputBrowse_Click"
              Style="{StaticResource AccentButtonStyle}" />
            <Button
              Content="Select archive..."
              Click="SelectArchive_Click" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Video preview panel -->
      <Border
        x:Name="PreviewPanel"
        Grid.Column="2"
        VerticalAlignment="Top"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <StackPanel Spacing="12" Margin="4">

          <!-- Video display area -->
          <Border Background="#FF1E1E1E"
                  CornerRadius="4"
                  MinHeight="200"
                  Padding="0"
                  HorizontalAlignment="Stretch">
            <Grid>
              <MediaPlayerElement x:Name="VideoPlayer"
                                  AreTransportControlsEnabled="False"
                                  Stretch="Uniform"
                                  MaxHeight="264"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              <FontIcon x:Name="VideoPlaceholderIcon"
                        FontSize="48"
                        Glyph="&#xE714;"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
              <ProgressRing x:Name="PreviewLoading"
                            IsActive="False"
                            Width="32" Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- File name -->
          <TextBlock x:Name="PreviewFileNameText"
                     HorizontalAlignment="Center"
                     FontSize="12"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="340" />

          <!-- Info text -->
          <TextBlock x:Name="PreviewInfoText"
                     HorizontalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     MaxWidth="340" />

          <!-- Playback position slider -->
          <Slider x:Name="PlaybackSlider"
                  Minimum="0"
                  Maximum="100"
                  Value="0"
                  HorizontalAlignment="Stretch"
                  Margin="0,4,0,0"
                  ValueChanged="PlaybackSlider_ValueChanged" />

          <!-- Time display -->
          <Grid Margin="0,-8,0,0">
            <TextBlock x:Name="CurrentTimeText"
                       Text="0:00"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Left" />
            <TextBlock x:Name="TotalTimeText"
                       Text="0:00"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Right" />
          </Grid>

          <!-- Transport controls -->
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <Button x:Name="StopButton"
                    Click="StopButton_Click"
                    Padding="8"
                    MinWidth="0"
                    IsEnabled="False"
                    ToolTipService.ToolTip="Stop">
              <FontIcon FontSize="14" Glyph="&#xE71A;" />
            </Button>
            <Button x:Name="PlayPauseButton"
                    Click="PlayPauseButton_Click"
                    Padding="8"
                    MinWidth="0"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Play">
              <FontIcon x:Name="PlayPauseIcon" FontSize="16" Glyph="&#xE768;" />
            </Button>
          </StackPanel>

          <!-- Error display -->
          <TextBlock x:Name="PreviewErrorText"
                     HorizontalAlignment="Center"
                     Foreground="Red"
                     FontSize="11"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     MaxWidth="340"
                     Visibility="Collapsed" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ConversionProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="0" Grid.Column="2"
                  Orientation="Horizontal" Spacing="4">
        <Button Content="Browse folder..."
                MinWidth="120"
                Click="InputBrowse_Click" />
        <Button Content="Select archive..."
                MinWidth="120"
                Click="SelectArchive_Click" />
      </StackPanel>

      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="OutputPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="1" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button
          Content="Browse..."
          MinWidth="120"
          Click="OutputBrowse_Click" />
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
        <Button
          x:Name="ConvertButton"
          Content="Convert"
          MinWidth="120"
          Click="ConvertButton_Click"
          IsEnabled="False"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>

    <!-- ffmpeg warning bar -->
    <InfoBar
      x:Name="FfmpegWarning"
      Grid.Row="0"
      Title="ffmpeg not found"
      Message="Install ffmpeg (ffmpeg.org) and ensure it's on your PATH to enable video conversion."
      Severity="Warning"
      IsOpen="False"
      IsClosable="False"
      VerticalAlignment="Top"
      HorizontalAlignment="Stretch" />
  </Grid>
</UserControl>
