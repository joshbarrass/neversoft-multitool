<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.ScriptDecompilerTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <UserControl.Resources>
    <local:ExpandableListTemplateSelector x:Key="ListTemplateSelector">

      <!-- Parent row: script file (TRG or QB) -->
      <local:ExpandableListTemplateSelector.ParentTemplate>
        <DataTemplate>
          <Grid Style="{StaticResource ListItemRowGridStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="28" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="60" />
              <ColumnDefinition Width="60" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Button
              Grid.Column="0"
              Padding="0"
              MinWidth="0"
              MinHeight="0"
              Width="24" Height="24"
              Background="Transparent"
              BorderThickness="0"
              Click="ExpandCollapse_Click"
              Tag="{Binding}"
              VerticalAlignment="Center">
              <FontIcon
                FontSize="10"
                Glyph="{Binding ChevronGlyph}" />
            </Button>
            <TextBlock
              Grid.Column="1"
              VerticalAlignment="Center"
              Text="{Binding FileName}"
              TextTrimming="CharacterEllipsis"
              ToolTipService.ToolTip="{Binding FileName}" />
            <TextBlock
              Grid.Column="2"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Text="{Binding VersionDisplay}" />
            <TextBlock
              Grid.Column="3"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Text="{Binding NodeCountDisplay}" />
            <TextBlock
              Grid.Column="4"
              VerticalAlignment="Center"
              Foreground="{Binding StatusColor}"
              Text="{Binding StatusDisplay}" />
          </Grid>
        </DataTemplate>
      </local:ExpandableListTemplateSelector.ParentTemplate>

      <!-- Child row: TRG node or QB item -->
      <local:ExpandableListTemplateSelector.ChildTemplate>
        <DataTemplate>
          <Grid Style="{StaticResource ListItemRowGridStyle}"
                Padding="28,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="50" />
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
              Grid.Column="0"
              VerticalAlignment="Center"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Text="{Binding IndexDisplay}" />
            <TextBlock
              Grid.Column="1"
              VerticalAlignment="Center"
              FontWeight="SemiBold"
              Text="{Binding TypeDisplay}" />
            <TextBlock
              Grid.Column="2"
              VerticalAlignment="Center"
              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
              Text="{Binding SummaryDisplay}"
              TextTrimming="CharacterEllipsis" />
          </Grid>
        </DataTemplate>
      </local:ExpandableListTemplateSelector.ChildTemplate>

    </local:ExpandableListTemplateSelector>
  </UserControl.Resources>

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Script Decompiler"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="View and export Neversoft TRG trigger files and QB compiled scripts"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: file list + detail panel -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition x:Name="DetailSplitterColumn" Width="0" />
        <ColumnDefinition x:Name="DetailColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <controls:GridSplitter
        x:Name="DetailSplitter"
        Grid.Column="1"
        Width="8"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Columns"
        Visibility="Collapsed" />

      <!-- File list card -->
      <Border
        x:Name="FileListCard"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <Grid VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Column headers -->
          <Grid Grid.Row="0"
                Style="{StaticResource ColumnHeaderGridStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="28" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="60" />
              <ColumnDefinition Width="60" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="File Name" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Format" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="Items" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" />
          </Grid>

          <!-- Files ListView -->
          <ListView
            x:Name="FilesListView"
            Grid.Row="1"
            SelectionMode="Single"
            Style="{StaticResource FileListViewStyle}"
            SelectionChanged="FilesListView_SelectionChanged"
            ItemTemplateSelector="{StaticResource ListTemplateSelector}" />
        </Grid>
      </Border>

      <!-- Empty state -->
      <Border
        x:Name="EmptyStatePanel"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <FontIcon FontSize="64"
                    Glyph="&#xE81E;"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock
            Text="No files loaded"
            FontSize="18"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextAlignment="Center" />
          <TextBlock
            Text="Open a .trg or .qb file, or browse a directory"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            TextAlignment="Center" />
          <Button
            Content="Browse..."
            HorizontalAlignment="Center"
            Click="InputBrowse_Click"
            Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
      </Border>

      <!-- Detail panel -->
      <Border
        x:Name="DetailPanel"
        Grid.Column="2"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="8" Margin="4">

            <!-- Header: type badge + index -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                      CornerRadius="4" Padding="8,2">
                <TextBlock x:Name="DetailTypeText" FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
              </Border>
              <TextBlock x:Name="DetailIndexText" Grid.Column="1"
                         VerticalAlignment="Center" Margin="8,0,0,0"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         FontSize="12" />
            </Grid>

            <!-- Separator -->
            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Properties section (TRG) -->
            <StackPanel x:Name="PropertiesSection" Spacing="4">
              <TextBlock Text="Properties" FontWeight="SemiBold" FontSize="12" />
              <Grid x:Name="PropertiesGrid" RowSpacing="4" ColumnSpacing="8" />
            </StackPanel>

            <!-- Position section (TRG) -->
            <StackPanel x:Name="PositionSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock Text="Position" FontWeight="SemiBold" FontSize="12" />
              <TextBlock x:Name="DetailPositionText" FontSize="12"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Angles section (TRG) -->
            <StackPanel x:Name="AnglesSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock Text="Angles" FontWeight="SemiBold" FontSize="12" />
              <TextBlock x:Name="DetailAnglesText" FontSize="12"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Links section (TRG) -->
            <StackPanel x:Name="LinksSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock Text="Links" FontWeight="SemiBold" FontSize="12" />
              <TextBlock x:Name="DetailLinksText" FontSize="12"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <!-- Commands section (TRG) -->
            <StackPanel x:Name="CommandsSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock x:Name="CommandsHeaderText" FontWeight="SemiBold"
                         FontSize="12" />
              <ItemsRepeater x:Name="CommandsRepeater">
                <ItemsRepeater.ItemTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </StackPanel>

            <!-- Script section (TRG) -->
            <StackPanel x:Name="ScriptSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock x:Name="ScriptHeaderText" FontWeight="SemiBold"
                         FontSize="12" />
              <ItemsRepeater x:Name="ScriptRepeater">
                <ItemsRepeater.ItemTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </StackPanel>

            <!-- Raw hex section (TRG) -->
            <StackPanel x:Name="RawHexSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock Text="Raw Hex" FontWeight="SemiBold" FontSize="12" />
              <TextBlock x:Name="DetailRawHexText" FontSize="11"
                         FontFamily="Consolas"
                         Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                         TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </StackPanel>

            <!-- Source section (QB decompiled output) -->
            <StackPanel x:Name="SourceSection" Spacing="4"
                        Visibility="Collapsed">
              <TextBlock x:Name="SourceHeaderText" FontWeight="SemiBold"
                         FontSize="12" />
              <TextBlock x:Name="DetailSourceText" FontSize="11"
                         FontFamily="Consolas"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ExportProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="0" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Open File..."
                MinWidth="100"
                Click="OpenFile_Click" />
        <Button Content="Browse Dir..."
                MinWidth="100"
                Click="InputBrowse_Click" />
      </StackPanel>

      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="OutputPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="1" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Browse..."
                MinWidth="80"
                Click="OutputBrowse_Click" />
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
        <Button
          x:Name="ExportButton"
          Content="Export"
          MinWidth="120"
          Click="ExportButton_Click"
          IsEnabled="False"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
