<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.HashReviewerTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Hash Reviewer"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Review brute-force candidates to build the QBKey name dictionary"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
      <StackPanel
        Grid.Column="1"
        Style="{StaticResource SelectButtonsPanelStyle}">
        <Button
          x:Name="ExportButton"
          Content="Export Dictionary"
          Click="ExportButton_Click"
          IsEnabled="False" />
      </StackPanel>
    </Grid>

    <!-- Main content: texture preview + candidate panel -->
    <Border
      x:Name="ReviewCard"
      Grid.Row="1"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}"
      Visibility="Collapsed">
      <Grid VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Texture preview -->
        <StackPanel Grid.Column="0"
                    Width="260"
                    Margin="8"
                    VerticalAlignment="Top"
                    Spacing="8">
          <Border Background="#FF1E1E1E"
                  CornerRadius="4"
                  MinHeight="200"
                  Padding="4"
                  HorizontalAlignment="Stretch">
            <Grid>
              <Image x:Name="TexturePreview"
                     MaxWidth="248"
                     MaxHeight="248"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
              <FontIcon x:Name="NoPreviewIcon"
                        FontSize="48"
                        Glyph="&#xE8B9;"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
            </Grid>
          </Border>
          <TextBlock x:Name="TextureDimensionsText"
                     HorizontalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     MaxWidth="248"
                     TextAlignment="Center" />
        </StackPanel>

        <!-- Right: Hash info + candidates -->
        <Grid Grid.Column="1"
              Margin="8"
              VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Hash info card -->
          <Border Grid.Row="0"
                  Padding="12"
                  Margin="0,0,0,8"
                  Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                  CornerRadius="4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Hash:" FontWeight="SemiBold" />
                  <TextBlock x:Name="HashValueText" Text="-" IsTextSelectionEnabled="True" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Type:" FontWeight="SemiBold" />
                  <TextBlock x:Name="HashTypeText" Text="-" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Files:" FontWeight="SemiBold" />
                  <TextBlock x:Name="HashFilesText" Text="-"
                             TextTrimming="CharacterEllipsis"
                             ToolTipService.ToolTip="-" />
                </StackPanel>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <TextBlock x:Name="ProgressText"
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
              </StackPanel>
            </Grid>
          </Border>

          <!-- Candidate filter -->
          <TextBox Grid.Row="1"
                   x:Name="CandidateFilterText"
                   PlaceholderText="Filter candidates..."
                   FontFamily="Consolas"
                   Margin="0,0,0,4"
                   TextChanged="CandidateFilter_TextChanged" />

          <!-- Candidates header -->
          <TextBlock Grid.Row="2"
                     x:Name="CandidatesHeaderText"
                     Text="Candidates:"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4" />

          <!-- Candidates list -->
          <ListView Grid.Row="3"
                    x:Name="CandidatesListView"
                    SelectionMode="None">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="local:HashCandidate">
                <Grid Margin="0,2" Padding="4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="{x:Bind Name}"
                             VerticalAlignment="Center"
                             FontFamily="Consolas"
                             FontSize="14" />
                  <TextBlock Grid.Column="1"
                             Text="{x:Bind Display}"
                             VerticalAlignment="Center"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                             FontSize="12"
                             Margin="8,0"
                             Visibility="Collapsed" />
                  <Button Grid.Column="2"
                          Content="Accept"
                          MinWidth="70"
                          Click="AcceptCandidate_Click"
                          Tag="{x:Bind Name}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <!-- Pagination -->
          <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="PrevPageButton"
                    Grid.Column="0"
                    Content="&lt; Prev 10"
                    Click="PrevPage_Click"
                    IsEnabled="False" />
            <TextBlock x:Name="PageInfoText"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button x:Name="NextPageButton"
                    Grid.Column="2"
                    Content="Next 10 &gt;"
                    Click="NextPage_Click"
                    IsEnabled="False" />
          </Grid>

          <!-- Manual entry -->
          <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Manual:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox x:Name="ManualEntryText"
                     Grid.Column="1"
                     PlaceholderText="Type a name..."
                     Margin="0,0,8,0"
                     FontFamily="Consolas" />
            <Button Grid.Column="2"
                    Content="Accept"
                    MinWidth="70"
                    Click="ManualAccept_Click" />
          </Grid>
        </Grid>
      </Grid>
    </Border>

    <!-- Empty state -->
    <Border
      x:Name="EmptyStatePanel"
      Grid.Row="1"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16">
        <FontIcon FontSize="64"
                  Glyph="&#xE71C;"
                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <TextBlock
          Text="No candidates loaded"
          FontSize="18"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          TextAlignment="Center" />
        <TextBlock
          Text="Load a review_candidates.json file and set the builds directory to begin"
          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
          TextAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- I/O Section -->
    <Grid Grid.Row="2"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Builds:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="BuildsDirText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="0" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="BuildsBrowse_Click" />

      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Candidates:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="CandidatesPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="1" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="CandidatesBrowse_Click" />
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ReviewProgress"
      Grid.Row="3"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- Navigation Buttons -->
    <Grid Grid.Row="4" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button x:Name="PrevHashButton"
              Grid.Column="0"
              Content="&lt; Previous Hash"
              MinWidth="120"
              Click="PrevHash_Click"
              IsEnabled="False" />
      <Button x:Name="SkipButton"
              Grid.Column="1"
              Content="Skip"
              MinWidth="80"
              HorizontalAlignment="Center"
              Click="SkipHash_Click"
              IsEnabled="False" />
      <Button x:Name="NextHashButton"
              Grid.Column="2"
              Content="Next Hash &gt;"
              MinWidth="120"
              Click="NextHash_Click"
              IsEnabled="False" />
    </Grid>
  </Grid>
</UserControl>
