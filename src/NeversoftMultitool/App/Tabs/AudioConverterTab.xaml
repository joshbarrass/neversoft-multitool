<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.AudioConverterTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Audio Conversion"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Convert ADX, XA, VAB, and KAT audio files to WAV"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- File list card -->
    <Border
      x:Name="FileListCard"
      Grid.Row="1"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}"
      Visibility="Collapsed">
      <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Column headers -->
        <Grid Grid.Row="0"
              Style="{StaticResource ColumnHeaderGridStyle}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="70" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="100" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" Text="Format" FontWeight="SemiBold" />
          <TextBlock Grid.Column="2" Text="Samples" FontWeight="SemiBold" HorizontalAlignment="Center" />
          <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" />
        </Grid>

        <!-- Files ListView -->
        <ListView
          x:Name="FilesListView"
          Grid.Row="1"
          Style="{StaticResource FileListViewStyle}">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="local:AudioFileEntry">
              <Grid Style="{StaticResource ListItemRowGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="70" />
                  <ColumnDefinition Width="80" />
                  <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  Text="{x:Bind FileName}"
                  TextTrimming="CharacterEllipsis"
                  ToolTipService.ToolTip="{x:Bind FileName}" />
                <TextBlock
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Text="{x:Bind AudioFormat}" />
                <TextBlock
                  Grid.Column="2"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Text="{x:Bind SampleCountDisplay, Mode=OneWay}" />
                <TextBlock
                  Grid.Column="3"
                  VerticalAlignment="Center"
                  Foreground="{x:Bind StatusColor, Mode=OneWay}"
                  Text="{x:Bind StatusDisplay, Mode=OneWay}" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Empty state -->
    <Border
      x:Name="EmptyStatePanel"
      Grid.Row="1"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16">
        <FontIcon FontSize="64"
                  Glyph="&#xE8D6;"
                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <TextBlock
          Text="No directory selected"
          FontSize="18"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          TextAlignment="Center" />
        <TextBlock
          Text="Select a directory containing .adx, .xa, .vab, or .kat audio files"
          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
          TextAlignment="Center" />
        <Button
          Content="Browse..."
          HorizontalAlignment="Center"
          Click="InputBrowse_Click"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Border>

    <!-- I/O Section -->
    <Grid Grid.Row="2"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="0" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="InputBrowse_Click" />

      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="OutputPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="1" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="OutputBrowse_Click" />

      <TextBlock Grid.Row="2" Grid.Column="0"
                 Text="VAB Rate:"
                 Style="{StaticResource IoLabelStyle}" />
      <ComboBox x:Name="VabSampleRateCombo"
                Grid.Row="2" Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                SelectedIndex="0">
        <ComboBoxItem Content="11025 Hz" />
        <ComboBoxItem Content="22050 Hz" />
        <ComboBoxItem Content="44100 Hz" />
      </ComboBox>
      <StackPanel Grid.Row="2" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
        <Button
          x:Name="ConvertButton"
          Content="Convert"
          MinWidth="120"
          Click="ConvertButton_Click"
          IsEnabled="False"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ConversionProgress"
      Grid.Row="3"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />
  </Grid>
</UserControl>
