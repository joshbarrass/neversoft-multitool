<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.MeshConverterTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Mesh Conversion"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Convert PSX and DDM mesh files to glTF (.glb)"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: file list -->
    <Grid Grid.Row="1">

      <!-- File list card -->
      <Border
        x:Name="FileListCard"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <Grid VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Column headers -->
          <Grid Grid.Row="0"
                Style="{StaticResource ColumnHeaderGridStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="70" />
              <ColumnDefinition Width="70" />
              <ColumnDefinition Width="70" />
              <ColumnDefinition Width="80" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" Margin="8,0,0,0" />
            <TextBlock Grid.Column="1" Text="Format" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="Objects" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="Meshes" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="Triangles" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="5" Text="Status" FontWeight="SemiBold" />
          </Grid>

          <!-- Files ListView -->
          <ListView
            x:Name="FilesListView"
            Grid.Row="1"
            SelectionMode="Single"
            Style="{StaticResource FileListViewStyle}">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="local:MeshFileEntry">
                <Grid Style="{StaticResource ListItemRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="100" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Text="{x:Bind FileName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTipService.ToolTip="{x:Bind FileName}" />
                  <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind FormatDisplay}" />
                  <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind ObjectsDisplay}" />
                  <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind MeshesDisplay}" />
                  <TextBlock
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Text="{x:Bind TrianglesDisplay, Mode=OneWay}" />
                  <TextBlock
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    Foreground="{x:Bind StatusColor, Mode=OneWay}"
                    Text="{x:Bind StatusDisplay, Mode=OneWay}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Empty state when no directory selected -->
      <Border
        x:Name="EmptyStatePanel"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <FontIcon FontSize="64"
                    Glyph="&#xF158;"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock
            Text="No directory selected"
            FontSize="18"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextAlignment="Center" />
          <TextBlock
            Text="Select a game directory — companion files (DDX, PSX, _o) are resolved automatically"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            TextAlignment="Center" />
          <Button
            Content="Browse..."
            HorizontalAlignment="Center"
            Click="InputBrowse_Click"
            Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ConversionProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Input directory -->
      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="0" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="InputBrowse_Click" />

      <!-- Output directory + Embed Textures checkbox -->
      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <Grid Grid.Row="1" Grid.Column="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="OutputPathText"
                 Grid.Column="0"
                 IsReadOnly="True"
                 Style="{StaticResource IoTextBoxStyle}" />
        <CheckBox x:Name="EmbedTexturesCheckbox"
                  Grid.Column="1"
                  Content="Embed Textures"
                  IsChecked="True"
                  MinWidth="0"
                  Margin="8,0,16,0" />
      </Grid>
      <Button Grid.Row="1" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="OutputBrowse_Click" />
    </Grid>

    <!-- Action Row -->
    <Grid Grid.Row="4" Margin="0,8,0,0">
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
        <Button
          x:Name="ConvertButton"
          Content="Convert"
          MinWidth="120"
          Click="ConvertButton_Click"
          IsEnabled="False"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
