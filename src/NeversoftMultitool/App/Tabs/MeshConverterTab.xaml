<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.MeshConverterTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Mesh Conversion"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Convert mesh files to glTF (.glb)"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: file list + preview -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition x:Name="SplitterColumn" Width="0" />
        <ColumnDefinition x:Name="PreviewColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <controls:GridSplitter
        x:Name="PreviewSplitter"
        Grid.Column="1"
        Width="8"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Columns"
        Visibility="Collapsed" />

      <!-- Left: file list -->
      <Grid Grid.Column="0">

        <!-- File list card -->
        <Border
          x:Name="FileListCard"
          VerticalAlignment="Stretch"
          Style="{StaticResource CardBorderStyle}"
          Visibility="Collapsed">
          <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Grid Grid.Row="0"
                  Style="{StaticResource ColumnHeaderGridStyle}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="100" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" Margin="8,0,0,0" />
              <TextBlock Grid.Column="1" Text="Format" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="Objects" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="Meshes" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="4" Text="Triangles" FontWeight="SemiBold" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="5" Text="Status" FontWeight="SemiBold" />
            </Grid>

            <!-- Files ListView -->
            <ListView
              x:Name="FilesListView"
              Grid.Row="1"
              SelectionMode="Single"
              SelectionChanged="FilesListView_SelectionChanged"
              Style="{StaticResource FileListViewStyle}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:MeshFileEntry">
                  <Grid Style="{StaticResource ListItemRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="80" />
                      <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      Grid.Column="0"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Text="{x:Bind RelativePath}"
                      TextTrimming="CharacterEllipsis"
                      ToolTipService.ToolTip="{x:Bind FilePath}" />
                    <TextBlock
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Text="{x:Bind FormatDisplay}" />
                    <TextBlock
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Text="{x:Bind ObjectsDisplay}" />
                    <TextBlock
                      Grid.Column="3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Text="{x:Bind MeshesDisplay}" />
                    <TextBlock
                      Grid.Column="4"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Text="{x:Bind TrianglesDisplay, Mode=OneWay}" />
                    <TextBlock
                      Grid.Column="5"
                      VerticalAlignment="Center"
                      Foreground="{x:Bind StatusColor, Mode=OneWay}"
                      Text="{x:Bind StatusDisplay, Mode=OneWay}" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

        <!-- Empty state when no directory selected -->
        <Border
          x:Name="EmptyStatePanel"
          VerticalAlignment="Stretch"
          Style="{StaticResource CardBorderStyle}">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="16">
            <FontIcon FontSize="64"
                      Glyph="&#xF158;"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
              Text="No directory selected"
              FontSize="18"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              TextAlignment="Center" />
            <TextBlock
              Text="Select a folder (scanned recursively) or a .pak.ps2 worldzone archive. Companion files (DDX, PSX, TEX, SKE) are resolved automatically."
              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
              TextAlignment="Center"
              TextWrapping="Wrap"
              MaxWidth="480" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
              <Button
                Content="Browse folder..."
                Click="InputBrowse_Click"
                Style="{StaticResource AccentButtonStyle}" />
              <Button
                Content="Select archive..."
                Click="SelectArchive_Click" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Right: 3D preview panel -->
      <Grid x:Name="PreviewPanel"
            Grid.Column="2"
            Margin="8,0,0,0"
            Visibility="Collapsed">
        <Border Style="{StaticResource CardBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- WebView2 3D viewer -->
            <WebView2
              x:Name="ModelViewer"
              Grid.Row="0" />

            <!-- Loading overlay -->
            <ProgressRing
              x:Name="PreviewLoadingRing"
              Grid.Row="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsActive="False"
              Visibility="Collapsed" />

            <!-- Model info + error -->
            <StackPanel Grid.Row="1"
                        Padding="12,8"
                        Spacing="2">
              <TextBlock
                x:Name="PreviewInfoText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontSize="12"
                TextWrapping="Wrap" />
              <TextBlock
                x:Name="PreviewErrorText"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                FontSize="12"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ConversionProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Input directory or archive -->
      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="0" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="4">
        <Button Content="Browse folder..."
                MinWidth="120"
                Click="InputBrowse_Click" />
        <Button Content="Select archive..."
                MinWidth="120"
                Click="SelectArchive_Click" />
      </StackPanel>

      <!-- Output directory -->
      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="OutputPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="1" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="OutputBrowse_Click" />
    </Grid>

    <!-- Action Row -->
    <Grid Grid.Row="4" Margin="0,8,0,0">
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
        <Button
          x:Name="ConvertButton"
          Content="Convert"
          MinWidth="120"
          Click="ConvertButton_Click"
          IsEnabled="False"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
