<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.UnpackTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Game Unpacker"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Unpack all game archives in a directory, including nested archives"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Stats card -->
    <Border
      x:Name="StatsCard"
      Grid.Row="1"
      Margin="0,0,0,8"
      Style="{StaticResource CardBorderStyle}"
      Visibility="Collapsed">
      <Grid Padding="12">
        <StackPanel Orientation="Horizontal" Spacing="24">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Archives:" FontWeight="SemiBold" />
            <TextBlock x:Name="TotalArchivesText" Text="0" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="To extract:" FontWeight="SemiBold" />
            <TextBlock x:Name="PendingArchivesText" Text="0" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Already done:" FontWeight="SemiBold" />
            <TextBlock x:Name="SkippedArchivesText" Text="0" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Archive list card -->
    <Border
      x:Name="FileListCard"
      Grid.Row="2"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}"
      Visibility="Collapsed">
      <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Column headers -->
        <Grid Grid.Row="0"
              Style="{StaticResource ColumnHeaderGridStyle}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="100" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Archive" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold" />
          <TextBlock Grid.Column="2" Text="Status" FontWeight="SemiBold" />
        </Grid>

        <!-- Archives ListView -->
        <ListView
          x:Name="ArchivesListView"
          Grid.Row="1"
          Style="{StaticResource FileListViewStyle}">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="local:UnpackArchiveEntry">
              <Grid Style="{StaticResource ListItemRowGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="60" />
                  <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  Text="{x:Bind RelativePath}"
                  TextTrimming="CharacterEllipsis"
                  ToolTipService.ToolTip="{x:Bind FilePath}" />
                <TextBlock
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Text="{x:Bind ArchiveType}" />
                <TextBlock
                  Grid.Column="2"
                  VerticalAlignment="Center"
                  Foreground="{x:Bind StatusColor, Mode=OneWay}"
                  Text="{x:Bind StatusDisplay, Mode=OneWay}" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Empty state -->
    <Border
      x:Name="EmptyStatePanel"
      Grid.Row="2"
      VerticalAlignment="Stretch"
      Style="{StaticResource CardBorderStyle}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16">
        <FontIcon FontSize="64"
                  Glyph="&#xE74C;"
                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <TextBlock
          Text="No directory selected"
          FontSize="18"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          TextAlignment="Center" />
        <TextBlock
          Text="Select a game root directory to scan for archives"
          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
          TextAlignment="Center" />
        <Button
          Content="Browse..."
          HorizontalAlignment="Center"
          Click="InputBrowse_Click"
          Style="{StaticResource AccentButtonStyle}" />
      </StackPanel>
    </Border>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="UnpackProgress"
      Grid.Row="3"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section (input only) -->
    <Grid Grid.Row="4"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="Root:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="InputBrowse_Click" />
    </Grid>

    <!-- Action Buttons -->
    <StackPanel
      Grid.Row="5"
      HorizontalAlignment="Right"
      Orientation="Horizontal"
      Spacing="8"
      Margin="0,8,0,0">
      <Button
        x:Name="CancelButton"
        Content="Cancel"
        MinWidth="80"
        Click="CancelButton_Click"
        Visibility="Collapsed" />
      <Button
        x:Name="UnpackButton"
        Content="Unpack All"
        MinWidth="120"
        Click="UnpackButton_Click"
        IsEnabled="False"
        Style="{StaticResource AccentButtonStyle}" />
    </StackPanel>
  </Grid>
</UserControl>
