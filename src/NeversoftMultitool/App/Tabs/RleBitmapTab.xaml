<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.RleBitmapTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="RLE / BMR Bitmap Conversion"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Convert Neversoft RLE and BMR bitmap files to PNG"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: file list + preview -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition x:Name="SplitterColumn" Width="0" />
        <ColumnDefinition x:Name="PreviewColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <controls:GridSplitter
        x:Name="PreviewSplitter"
        Grid.Column="1"
        Width="8"
        ResizeBehavior="PreviousAndNext"
        ResizeDirection="Columns"
        Visibility="Collapsed" />

      <!-- File list card -->
      <Border
        x:Name="FileListCard"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <Grid VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Column headers -->
          <Grid Grid.Row="0"
                Style="{StaticResource ColumnHeaderGridStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="70" />
              <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Width" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Status" FontWeight="SemiBold" />
          </Grid>

          <!-- Files ListView -->
          <ListView
            x:Name="FilesListView"
            Grid.Row="1"
            SelectionMode="Single"
            Style="{StaticResource FileListViewStyle}"
            SelectionChanged="FilesListView_SelectionChanged">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="local:RleFileEntry">
                <Grid Style="{StaticResource ListItemRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="100" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{x:Bind FileName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTipService.ToolTip="{x:Bind FileName}" />
                  <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{x:Bind WidthDisplay, Mode=OneWay}" />
                  <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="{x:Bind StatusColor, Mode=OneWay}"
                    Text="{x:Bind StatusDisplay, Mode=OneWay}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <!-- Empty state -->
      <Border
        x:Name="EmptyStatePanel"
        Grid.Column="0"
        VerticalAlignment="Stretch"
        Style="{StaticResource CardBorderStyle}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <FontIcon FontSize="64"
                    Glyph="&#xE8B9;"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock
            Text="No directory selected"
            FontSize="18"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextAlignment="Center" />
          <TextBlock
            Text="Select a folder of .rle/.bmr/.zlb files or a game archive (WAD/PRE/PKR/...)"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            TextAlignment="Center"
            TextWrapping="Wrap"
            MaxWidth="420" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <Button
              Content="Browse folder..."
              Click="InputBrowse_Click"
              Style="{StaticResource AccentButtonStyle}" />
            <Button
              Content="Select archive..."
              Click="SelectArchive_Click" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Preview panel -->
      <Border
        x:Name="PreviewPanel"
        Grid.Column="2"
        VerticalAlignment="Top"
        Style="{StaticResource CardBorderStyle}"
        Visibility="Collapsed">
        <StackPanel Spacing="8" Margin="4">
          <Border Background="#FF1E1E1E"
                  CornerRadius="4"
                  MinHeight="200"
                  Padding="4"
                  HorizontalAlignment="Stretch">
            <Grid>
              <Image x:Name="BitmapPreview"
                     MaxWidth="264"
                     MaxHeight="264"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
              <FontIcon x:Name="NoPreviewIcon"
                        FontSize="48"
                        Glyph="&#xE8B9;"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
              <ProgressRing x:Name="PreviewLoading"
                            IsActive="False"
                            Width="32" Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </Grid>
          </Border>
          <TextBlock x:Name="PreviewDimensionsText"
                     HorizontalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     FontSize="11" />
          <TextBlock x:Name="PreviewInfoText"
                     HorizontalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     MaxWidth="264" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="0" Grid.Column="2"
                  Orientation="Horizontal" Spacing="4">
        <Button Content="Browse folder..."
                MinWidth="120"
                Click="InputBrowse_Click" />
        <Button Content="Select archive..."
                MinWidth="120"
                Click="SelectArchive_Click" />
      </StackPanel>

      <TextBlock Grid.Row="1" Grid.Column="0"
                 Text="Output:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="OutputPathText"
               Grid.Row="1" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <Button Grid.Row="1" Grid.Column="2"
              Content="Browse..."
              MinWidth="120"
              Click="OutputBrowse_Click" />

      <TextBlock Grid.Row="2" Grid.Column="0"
                 Text="Width:"
                 Style="{StaticResource IoLabelStyle}" />
      <StackPanel Grid.Row="2" Grid.Column="1"
                  Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Left" VerticalAlignment="Center">
        <NumberBox x:Name="WidthNumberBox"
                   Value="512"
                   Minimum="1"
                   Maximum="1024"
                   SpinButtonPlacementMode="Compact"
                   SmallChange="1"
                   LargeChange="128"
                   IsEnabled="False"
                   ValueChanged="WidthNumberBox_ValueChanged" />
        <CheckBox x:Name="AutoWidthCheckbox"
                  Content="Auto"
                  IsChecked="True"
                  MinWidth="0"
                  Checked="AutoWidthCheckbox_Changed"
                  Unchecked="AutoWidthCheckbox_Changed" />
      </StackPanel>
      <Button x:Name="ConvertButton"
              Grid.Row="2" Grid.Column="2"
              Content="Convert"
              MinWidth="120"
              Click="ConvertButton_Click"
              IsEnabled="False"
              Style="{StaticResource AccentButtonStyle}" />
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="ConversionProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />
  </Grid>
</UserControl>
