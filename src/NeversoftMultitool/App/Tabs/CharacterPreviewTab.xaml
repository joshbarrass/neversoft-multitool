<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="NeversoftMultitool.CharacterPreviewTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:NeversoftMultitool"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <Grid Padding="16"
        VerticalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header row -->
    <Grid Grid.Row="0"
          Margin="0,0,0,8">
      <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
        <TextBlock
          Text="Character Preview"
          Style="{StaticResource SubtitleTextBlockStyle}" />
        <TextBlock
          Text="Pick a character, browse animations, preview in 3D, render to GIF, or export an animated GLB"
          Style="{StaticResource TabSubtitleStyle}" />
      </StackPanel>
    </Grid>

    <!-- Main content: character list | 3D viewer | animation panel -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="220" />
        <ColumnDefinition Width="*" MinWidth="320" />
        <ColumnDefinition Width="320" MinWidth="240" />
      </Grid.ColumnDefinitions>

      <!-- Left: character list -->
      <Grid Grid.Column="0">

        <Border
          x:Name="CharacterListCard"
          VerticalAlignment="Stretch"
          Style="{StaticResource CardBorderStyle}"
          Visibility="Collapsed">
          <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Style="{StaticResource ColumnHeaderGridStyle}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="80" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Character" FontWeight="SemiBold" Margin="8,0,0,0" />
              <TextBlock Grid.Column="1" Text="Bones" FontWeight="SemiBold" HorizontalAlignment="Center" />
            </Grid>

            <ListView
              x:Name="CharacterListView"
              Grid.Row="1"
              SelectionMode="Single"
              SelectionChanged="CharacterListView_SelectionChanged"
              Style="{StaticResource FileListViewStyle}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:CharacterEntry">
                  <Grid Style="{StaticResource ListItemRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      Grid.Column="0"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Text="{x:Bind FileName}"
                      TextTrimming="CharacterEllipsis"
                      ToolTipService.ToolTip="{x:Bind RelativePath}" />
                    <TextBlock
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Text="{x:Bind StatusDisplay, Mode=OneWay}" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

        <Border
          x:Name="EmptyStatePanel"
          VerticalAlignment="Stretch"
          Style="{StaticResource CardBorderStyle}">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="16">
            <FontIcon FontSize="64"
                      Glyph="&#xE77B;"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
              Text="No characters loaded"
              FontSize="18"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              TextAlignment="Center" />
            <TextBlock
              Text="Pick a folder (scanned recursively for skinned meshes) or a game archive."
              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
              TextAlignment="Center"
              TextWrapping="Wrap"
              MaxWidth="300" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
              <Button
                Content="Browse folder..."
                Click="InputBrowse_Click"
                Style="{StaticResource AccentButtonStyle}" />
              <Button
                Content="Select archive..."
                Click="SelectArchive_Click" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Middle: 3D viewer -->
      <Grid Grid.Column="1"
            Margin="8,0,8,0">
        <Border Style="{StaticResource CardBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <WebView2
              x:Name="ModelViewer"
              Grid.Row="0" />

            <ProgressRing
              x:Name="PreviewLoadingRing"
              Grid.Row="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsActive="False"
              Visibility="Collapsed" />

            <StackPanel Grid.Row="1"
                        Padding="12,8"
                        Spacing="2">
              <TextBlock
                x:Name="PreviewInfoText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontSize="12"
                TextWrapping="Wrap" />
              <TextBlock
                x:Name="PreviewErrorText"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                FontSize="12"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <!-- Right: animation panel -->
      <Grid Grid.Column="2">
        <Border Style="{StaticResource CardBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Animation panel header -->
            <StackPanel Grid.Row="0"
                        Padding="12,12,12,8"
                        Spacing="6">
              <TextBlock
                Text="Animations"
                FontWeight="SemiBold" />
              <TextBlock
                x:Name="AnimDiscoveryStatusText"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                FontSize="12"
                TextWrapping="Wrap"
                Text="Select a character to scan for animations." />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button
                  x:Name="AddAnimFolderButton"
                  Content="Add folder..."
                  Click="AddAnimFolder_Click"
                  IsEnabled="False" />
                <Button
                  x:Name="AddAnimArchiveButton"
                  Content="Add archive..."
                  Click="AddAnimArchive_Click"
                  IsEnabled="False" />
              </StackPanel>
            </StackPanel>

            <!-- List header -->
            <Grid Grid.Row="1"
                  Style="{StaticResource ColumnHeaderGridStyle}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="" />
              <TextBlock Grid.Column="1" Text="Animation" FontWeight="SemiBold" Margin="8,0,0,0" />
              <TextBlock Grid.Column="2" Text="Length" FontWeight="SemiBold" HorizontalAlignment="Right"
                         Margin="0,0,8,0" />
            </Grid>

            <!-- Animation list -->
            <ListView
              x:Name="AnimationListView"
              Grid.Row="2"
              SelectionMode="Single"
              SelectionChanged="AnimationListView_SelectionChanged"
              Style="{StaticResource FileListViewStyle}">
              <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:AnimationListEntry">
                  <Grid Style="{StaticResource ListItemRowGridStyle}"
                        ToolTipService.ToolTip="{x:Bind MismatchTooltip}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="32" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                      Grid.Column="0"
                      VerticalAlignment="Center"
                      Margin="6,0,0,0"
                      MinWidth="24"
                      IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                      IsEnabled="{x:Bind MatchesSkeleton}" />
                    <TextBlock
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Text="{x:Bind DisplayName}"
                      Foreground="{x:Bind RowForeground}"
                      TextTrimming="CharacterEllipsis" />
                    <TextBlock
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Margin="0,0,8,0"
                      Text="{x:Bind DurationDisplay}"
                      Foreground="{x:Bind RowForeground}" />
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>

            <!-- Action row -->
            <StackPanel Grid.Row="3"
                        Padding="12,8"
                        Spacing="4">
              <Button
                x:Name="RenderGifButton"
                Content="Render GIF..."
                HorizontalAlignment="Stretch"
                IsEnabled="False"
                Click="RenderGif_Click" />
              <Button
                x:Name="ConvertGlbButton"
                Content="Convert to GLB..."
                HorizontalAlignment="Stretch"
                IsEnabled="False"
                Click="ConvertGlb_Click"
                Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- Progress Bar -->
    <ProgressBar
      x:Name="OperationProgress"
      Grid.Row="2"
      Maximum="100"
      Style="{StaticResource TabProgressBarStyle}" />

    <!-- I/O Section -->
    <Grid Grid.Row="3"
          Style="{StaticResource IoSectionGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Input:"
                 Style="{StaticResource IoLabelStyle}" />
      <TextBox x:Name="InputPathText"
               Grid.Row="0" Grid.Column="1"
               IsReadOnly="True"
               Style="{StaticResource IoTextBoxStyle}" />
      <StackPanel Grid.Row="0" Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="4">
        <Button Content="Browse folder..."
                MinWidth="120"
                Click="InputBrowse_Click" />
        <Button Content="Select archive..."
                MinWidth="120"
                Click="SelectArchive_Click" />
      </StackPanel>
    </Grid>

    <!-- Action Row -->
    <Grid Grid.Row="4" Margin="0,8,0,0">
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
        <Button
          x:Name="CancelButton"
          Content="Cancel"
          MinWidth="80"
          Click="CancelButton_Click"
          Visibility="Collapsed" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
